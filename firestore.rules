rules_version = '2';

// Village OS — Firestore security rules.
//
// All reads and writes flow through Next.js API routes that use the Firebase
// Admin SDK (which bypasses these rules). The browser client never touches
// Firestore directly, so we deny everything here. This is the strongest
// posture: even if a client API key leaks, no data can be read or written
// outside the authenticated, rate-limited, role-checked API layer.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
